# =============================================================
# Reconciler – Environment Variables
# Copy to .env and fill in your actual values
# Do NOT commit .env to git
# =============================================================

# ── Postgres ──────────────────────────────────────────────────
POSTGRES_USER=reconciler
POSTGRES_PASSWORD=<REPLACE_WITH_STRONG_PASSWORD>
POSTGRES_DB=reconciler
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://reconciler:<REPLACE_WITH_STRONG_PASSWORD>@postgres:5432/reconciler

# ── NATS ──────────────────────────────────────────────────────
NATS_URL=nats://nats:4222
NATS_CLUSTER_ID=reconciler-cluster

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── API ───────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080
RUST_LOG=info,reconciler=debug
RUST_BACKTRACE=1

# ── Clerk Auth ────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_JWT_KEY=REPLACE_ME
CLERK_ORG_ID=org_REPLACE_ME

# ── Sandbox ───────────────────────────────────────────────────
SANDBOX_PORT=8081
SANDBOX_SEED=42

# ── AMOS Deployment (CI/CD) ───────────────────────────────────
AMOS_HOST=REPLACE_ME
AMOS_USER=deploy
AMOS_DEPLOY_PATH=/opt/reconciler

# ── Docker Registry ───────────────────────────────────────────
REGISTRY=ghcr.io
IMAGE_NAME=winston09-bit/reconciler
IMAGE_TAG=latest

# ── Notifications ─────────────────────────────────────────────
NOTIFY_EMAIL=REPLACE_ME
